# Copy this file to ".env" and fill in real values. Never commit ".env".

# Same Supabase project Person A used for the backend.
# Find these in Supabase Dashboard > Project Settings > API.
# Use the "anon public" key here, NOT the service role key.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-SUPABASE-ANON-KEY

# The FastAPI backend from Phase 1.
# - iOS simulator: http://127.0.0.1:8000
# - Physical phone on same Wi-Fi: http://<your-computer-IPv4>:8000
#   (run `python -m uvicorn app.main:app --reload --host 0.0.0.0` on the backend,
#   then find your IPv4 with `ipconfig`)
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000
